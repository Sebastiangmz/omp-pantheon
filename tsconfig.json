{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "allowJs": true,
    "types": ["bun-types"],
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "allowImportingTsExtensions": true,
    "noUncheckedIndexedAccess": true,
    "verbatimModuleSyntax": true
  },
  "include": ["hooks/**/*.ts", "tools/**/*.ts", "test/**/*.ts"],
  "exclude": ["node_modules", "**/node_modules", "extensions/oh-my-omp/node_modules"]
}
